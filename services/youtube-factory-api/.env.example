# Copy to .env and fill in values

# App
APP_NAME=YouTube Factory API
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://youtube_factory:dev_secret@localhost:5432/youtube_factory

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Image Generation
IMAGE_PROVIDER=dall-e-3
STABILITY_API_KEY=

# Voice Generation
VOICE_PROVIDER=openai-tts
ELEVENLABS_API_KEY=

# YouTube OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8001/auth/youtube/callback

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Concurrency
MAX_CONCURRENT_JOBS=3
